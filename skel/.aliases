alias dai='docker exec -it seungminDockImp bash'
alias das='docker exec -it seungminDock bash'
alias dim='docker images'
alias dps='docker ps -a'

alias cl='clear'
alias nv='nvitop --interval 1 --colorful'
alias tl='tmux ls'
alias ta='tmux attach -t'
alias tn='tmux new -s'
alias tk='tmux kill-session'
alias pt='python'
alias xl='tmuxp load'
alias pp='mlr --icsv --opprint --barred cat'
alias ppl='mlr --l2c --opprint --barred cat'
alias rs='rsync -avh'

alias ur='uv run python'
alias so='source ~/.venv/bin/activate'